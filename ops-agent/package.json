{
  "name": "hyperlane-ops-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-based Hyperlane operations orchestrator",
  "type": "module",
  "bin": {
    "ops-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "dev:cli": "tsx src/cli.ts",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "0.55.4",
    "@mariozechner/pi-coding-agent": "0.55.4",
    "@sinclair/typebox": "^0.34.41",
    "fastify": "^5.8.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
